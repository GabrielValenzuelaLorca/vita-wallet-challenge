# Rails
RAILS_ENV=development
# RAILS_MASTER_KEY=...  # not required if config/master.key exists locally
PORT=3000
RAILS_MAX_THREADS=5
RAILS_MIN_THREADS=5
WEB_CONCURRENCY=2

# Database (used by config/database.yml — empty values fall back to the local
# postgres defaults; docker-compose injects the values for the postgres service)
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_NAME=vita_wallet_development
DATABASE_TEST_NAME=vita_wallet_test
BACKEND_DATABASE_PASSWORD=

# Stable JWT signing key (only set when not using config/master.key; required
# for the docker-compose dev stack so JWTs survive container restarts)
# SECRET_KEY_BASE=

# Price provider
PRICE_CLIENT=stub  # stub | real
PRICE_API_TIMEOUT=5
# PRICE_API_URL=https://api.stage.vitawallet.io/api/prices_quote  # override only if pointing at a different upstream

# CORS
CORS_ORIGINS=http://localhost:5173
